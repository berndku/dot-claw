{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-cli",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "${workspaceFolder}/DotClaw.CLI/DotClaw.CLI.csproj", "/consoleloggerparameters:NoSummary;ForceNoAlign"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-gateway",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "${workspaceFolder}/DotClaw.Gateway/DotClaw.Gateway.csproj", "/consoleloggerparameters:NoSummary;ForceNoAlign"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-all",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "${workspaceFolder}/DotClaw.sln", "/consoleloggerparameters:NoSummary;ForceNoAlign"],
      "problemMatcher": "$msCompile"
    }
  ]
}
